# F1 Points Engine — Environment Variables
# Copy this file to .env: cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — zero setup, data stored locally)
DATABASE_URL=sqlite:///./f1_engine.db

# PostgreSQL example (use this on Railway for persistent data across deploys)
# DATABASE_URL=postgresql://user:password@host:5432/f1engine

# ── Server ────────────────────────────────────────────────────────────────────
# Port the backend listens on.
# Railway sets this automatically — do NOT override it on Railway.
PORT=8000

# ── Frontend build ────────────────────────────────────────────────────────────
# URL of the backend API, used only during `npm run build` for production.
# In development the Vite proxy handles this — this variable is not needed.
# On Railway the frontend is served by the same backend, so this can be left blank.
VITE_API_URL=http://localhost:8000
